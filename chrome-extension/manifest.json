{
  "manifest_version": 3,
  "name": "네이버 블로그 초안 자동입력",
  "version": "1.0",
  "description": "백엔드에서 AI 초안을 가져와 네이버 블로그 글쓰기 페이지에 자동 입력합니다.",
  "permissions": ["storage", "scripting", "activeTab"],
  "host_permissions": [
    "https://blog.naver.com/*",
    "https://naver-blog-backend.onrender.com/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "블로그 초안 불러오기"
  },
  "content_scripts": [
    {
      "matches": ["https://blog.naver.com/*/postwrite*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
