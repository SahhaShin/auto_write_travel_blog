<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.shincha.naverblog.model.dao.DraftDao">

    <resultMap id="DraftResultMap" type="BlogDraft">
        <id property="id" column="id"/>
        <result property="destination" column="destination"/>
        <result property="travelDates" column="travel_dates"/>
        <result property="itinerary" column="itinerary"/>
        <result property="keyPoints" column="key_points"/>
        <result property="category" column="category"/>
        <result property="generatedTitle" column="generated_title"/>
        <result property="finalTitle" column="final_title"/>
        <result property="generatedContent" column="generated_content"/>
        <result property="finalContent" column="final_content"/>
        <result property="styleSampleIds" column="style_sample_ids"/>
        <result property="claudeModel" column="claude_model"/>
        <result property="generationTokens" column="generation_tokens"/>
        <result property="status" column="status"/>
        <result property="naverPostUrl" column="naver_post_url"/>
        <result property="createdAt" column="created_at"/>
        <result property="userId" column="user_id"/>
        <result property="updatedAt" column="updated_at"/>
    </resultMap>

    <select id="findAllByUserId" resultMap="DraftResultMap">
        SELECT * FROM blog_drafts WHERE user_id = #{userId} ORDER BY created_at DESC
    </select>

    <select id="findById" parameterType="long" resultMap="DraftResultMap">
        SELECT * FROM blog_drafts WHERE id = #{id}
    </select>

    <insert id="insert" parameterType="BlogDraft" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO blog_drafts (user_id, destination, travel_dates, itinerary, key_points, category)
        VALUES (#{userId}, #{destination}, #{travelDates}, #{itinerary}, #{keyPoints}, #{category})
    </insert>

    <update id="update" parameterType="BlogDraft">
        UPDATE blog_drafts
        <set>
            <if test="finalTitle != null">final_title = #{finalTitle},</if>
            <if test="finalContent != null">final_content = #{finalContent},</if>
            <if test="status != null">status = #{status},</if>
            <if test="destination != null">destination = #{destination},</if>
            <if test="travelDates != null">travel_dates = #{travelDates},</if>
            <if test="itinerary != null">itinerary = #{itinerary},</if>
            <if test="keyPoints != null">key_points = #{keyPoints},</if>
        </set>
        WHERE id = #{id}
    </update>

    <update id="updateStatus">
        UPDATE blog_drafts SET status = #{status} WHERE id = #{id}
    </update>

    <update id="updateGenerated">
        UPDATE blog_drafts
        SET generated_title = #{title},
            generated_content = #{content},
            final_title = #{title},
            final_content = #{content},
            claude_model = #{model},
            generation_tokens = #{tokens},
            status = 'GENERATED'
        WHERE id = #{id}
    </update>

    <update id="updateNaverPostUrl">
        UPDATE blog_drafts
        SET naver_post_url = #{url}, status = 'POSTED'
        WHERE id = #{id}
    </update>

    <delete id="deleteById" parameterType="long">
        DELETE FROM blog_drafts WHERE id = #{id}
    </delete>

</mapper>
