<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.shincha.naverblog.model.dao.StyleDao">

    <resultMap id="StyleResultMap" type="BlogStyleSample">
        <id property="id" column="id"/>
        <result property="title" column="title"/>
        <result property="sourceUrl" column="source_url"/>
        <result property="content" column="content"/>
        <result property="category" column="category"/>
        <result property="styleTags" column="style_tags"/>
        <result property="createdAt" column="created_at"/>
        <result property="updatedAt" column="updated_at"/>
        <result property="userId" column="user_id"/>
        <result property="isActive" column="is_active"/>
    </resultMap>

    <select id="findAllByUserId" resultMap="StyleResultMap">
        SELECT * FROM blog_style_samples
        WHERE is_active = 1 AND user_id = #{userId} ORDER BY created_at DESC
    </select>

    <select id="findById" parameterType="long" resultMap="StyleResultMap">
        SELECT * FROM blog_style_samples WHERE id = #{id}
    </select>

    <select id="findActiveByCategory" parameterType="string" resultMap="StyleResultMap">
        SELECT * FROM blog_style_samples
        WHERE is_active = 1 AND category = #{category}
        ORDER BY created_at DESC
    </select>

    <insert id="insert" parameterType="BlogStyleSample" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO blog_style_samples (user_id, title, source_url, content, category, style_tags)
        VALUES (#{userId}, #{title}, #{sourceUrl}, #{content}, #{category}, #{styleTags})
    </insert>

    <update id="softDelete" parameterType="long">
        UPDATE blog_style_samples SET is_active = 0 WHERE id = #{id}
    </update>

</mapper>
